{
  "name": "nuglabs",
  "version": "1.2.3",
  "description": "Local-first SDK for the NugLabs strain API.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "index.d.ts",
    "src/dataset.json",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "check": "tsc --noEmit",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "nuglabs",
    "strains",
    "sdk",
    "api",
    "local-first",
    "cannabis",
    "weed"
  ],
  "devDependencies": {
    "@types/node": "^22.13.14",
    "tsup": "^8.3.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}