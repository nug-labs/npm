{
  "name": "nuglabs",
  "version": "1.3.3",
  "description": "Local-first SDK for the NugLabs strain API.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nug-labs/npm.git"
  },
  "homepage": "https://github.com/nug-labs/npm#readme",
  "bugs": {
    "url": "https://github.com/nug-labs/npm/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "wasm",
    "src/dataset.json",
    "src/rules.json",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build:wasm": "cd ../core && cargo build --release --target wasm32-unknown-unknown && mkdir -p ../npm/wasm && cp target/wasm32-unknown-unknown/release/nuglabs_core.wasm ../npm/wasm/",
    "build": "npm run build:wasm && tsup && mkdir -p dist/wasm && cp wasm/nuglabs_core.wasm dist/wasm/",
    "check": "tsc --noEmit",
    "test": "node --import tsx --test tests/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "nuglabs",
    "strains",
    "sdk",
    "api",
    "local-first",
    "cannabis",
    "weed"
  ],
  "devDependencies": {
    "@types/node": "^22.13.14",
    "tsup": "^8.3.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}